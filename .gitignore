# dvc.lock은 git에 추적됨 (실험 재현성 위해)

# Data (large files go to DVC)
# 소스 데이터셋: data/{dataset_name}/
# 실험 데이터: apps/research/{variant}/data/{experiment_name}/
data/*/
apps/research/*/data/*/
!data/.gitkeep
!apps/research/**/data/.gitkeep

# 대용량 파일 포맷 (모두 DVC로 관리)
*.parquet
*.npy
*.npz
*.h5
*.hdf5
*.pt          # PyTorch models
*.pth         # PyTorch checkpoints
*.pkl         # Pickle files
*.csv         # Large CSV files

# OS
.DS_Store
Thumbs.db
