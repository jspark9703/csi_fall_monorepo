[core]
    remote = gdrive-dvc
    autostage = true
[remote "gdrive-dvc"]
    url = gdrive://<GDRIVE_FOLDER_ID>
    # 설정 방법:
    # 1. Google Drive에서 DVC 캐시용 폴더 생성
    # 2. 폴더의 공유 링크에서 ID 추출: https://drive.google.com/drive/folders/{ID}
    # 3. 위의 <GDRIVE_FOLDER_ID>를 실제 ID로 교체
    # 4. dvc remote modify gdrive-dvc --local auth basic 으로 인증 설정
